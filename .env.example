# Land Your Web - Environment Variables
# Copy to .env.local and fill in values

# === SUPABASE ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === SITE ===
NEXT_PUBLIC_SITE_URL=https://landyourweb.com
NEXT_PUBLIC_SITE_NAME=Land Your Web

# === ANALYTICS (Plausible) ===
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=landyourweb.com
NEXT_PUBLIC_PLAUSIBLE_URL=https://plausible.io

# === EMAIL (Formspree or Resend) ===
NEXT_PUBLIC_FORMSPREE_ID=your-form-id
# or
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=hello@landyourweb.com

# === VERCEL ===
VERCEL_PROJECT_ID=your-project-id
VERCEL_ORG_ID=your-org-id
